        <script><![CDATA[var MediaUtilsClient = Class.create();
MediaUtilsClient.prototype = Object.extendsObject(global.AbstractAjaxProcessor, {
	getMediaData: function() {
		var media_sys_id = this.getParameter("sysparm_media_sys_id");
		var grMedia = new GlideRecord("x_1303339_netflix_media");
		grMedia.get(media_sys_id);

		return JSON.stringify({
			synopsis: grMedia.getValue("synopsis"),
			average_rating: grMedia.getValue("average_rating"),
			poster_url: grMedia.getValue("poster")
		});
	},
    type: 'MediaUtilsClient'
});]]></script>
