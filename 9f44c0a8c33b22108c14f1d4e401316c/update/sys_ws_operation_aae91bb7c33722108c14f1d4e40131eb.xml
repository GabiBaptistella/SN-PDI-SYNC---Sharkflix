        <enforce_acl>cf9d01d3e73003009d6247e603f6a990</enforce_acl>
        <http_method>GET</http_method>
        <name>Query Movies and Reviews</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {

	var returnArr = [];

	var grMedia = new GlideRecord("x_1303339_netflix_media");
	grMedia.query();
	while(grMedia.next()) {
		var movieObj = {
			"title": grMedia.getValue("title"),
			"release_year": grMedia.getValue("release_year"),
			"average_rating": grMedia.getValue("average_rating"),
			"reviews": []
		};

		var grReview = new GlideRecord("x_1303339_netflix_review");
		grReview.query("media", grMedia.getValue("sys_id"));
		grReview.query();
		while(grReview.next()) {
			movieObj["reviews"].push({
				"number": grReview.getValue("number"),
				"rating": grReview.getValue("rating"),
				"description": grReview.getValue("description"),
				"creator": grReview.opened_by.name.toString()

			});
		}
		returnArr.push(movieObj);

	}
	return returnArr;
	// return returnArr.push(movieObj);

})(request, response);]]></operation_script>
